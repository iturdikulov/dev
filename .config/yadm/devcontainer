#!/usr/bin/env bash

set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
cd "$script_dir"

run_runner() {
    local name="$1"
    local runner="$script_dir/runs/$name"

    if [[ ! -x "$runner" ]]; then
        echo "Runner is missing or not executable: $runner" >&2
        exit 1
    fi

    echo
    echo "==> Running $name"
    "$runner"
}

# Lean CLI/dev stack.
run_runner _libs
run_runner a_zsh
run_runner tmux
run_runner fzf
run_runner neovim
run_runner clang
run_runner node
run_runner python
run_runner go
run_runner _rust
run_runner _web
run_runner docker
run_runner dotnet
run_runner php
run_runner _terminal
run_runner _learning
run_runner aws-copilot
run_runner dolt

