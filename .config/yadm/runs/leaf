#!/usr/bin/env bash
set -euo pipefail

source "$(dirname -- "${BASH_SOURCE[0]}")/utils.sh"

REPO="RivoLink/leaf"
DEST_DIR="${1:-$HOME/.local/bin}"
DEST_BIN="$DEST_DIR/leaf"

detect_asset() {
    local os_name arch_name os_extra
    os_name="$(uname -s)"
    arch_name="$(uname -m)"
    os_extra="$(uname -o 2>/dev/null || true)"

    case "$os_name:$arch_name:$os_extra" in
        Linux:aarch64:Android | Linux:arm64:Android)
            echo "leaf-android-arm64"
            return 0
            ;;
    esac

    if [[ -n "${TERMUX_VERSION:-}" ]]; then
        case "$arch_name" in
            aarch64 | arm64)
                echo "leaf-android-arm64"
                return 0
                ;;
        esac
    fi

    case "$os_name" in
        Darwin)
            case "$arch_name" in
                x86_64 | amd64) echo "leaf-macos-x86_64" ;;
                arm64 | aarch64) echo "leaf-macos-arm64" ;;
                *)
                    log_error "Unsupported macOS architecture: $arch_name"
                    exit 1
                    ;;
            esac
            ;;
        Linux)
            case "$arch_name" in
                x86_64 | amd64) echo "leaf-linux-x86_64" ;;
                aarch64 | arm64) echo "leaf-linux-arm64" ;;
                *)
                    log_error "Unsupported Linux architecture: $arch_name"
                    exit 1
                    ;;
            esac
            ;;
        *)
            log_error "Unsupported platform: $os_name $arch_name"
            exit 1
            ;;
    esac
}

for c in sed uname mktemp chmod mkdir cp awk grep; do
    command_exists "$c" || {
        log_error "Missing required command: $c"
        exit 1
    }
done
command_exists sha256sum || command_exists shasum || {
    log_error "Missing sha256sum or shasum. Try: npm install -g @rivolink/leaf"
    exit 1
}
command_exists curl || command_exists wget || {
    log_error "Missing curl or wget"
    exit 1
}

asset_name="$(detect_asset)"
tag_name="$(github_latest_release_tag "$REPO")"

current_version=""
if [[ -x "$DEST_BIN" ]]; then
    current_version="$("$DEST_BIN" --version 2>/dev/null | awk '{print $2}')" || true
fi

if [[ -n "$current_version" ]]; then
    log_info "Updating leaf..."
else
    log_info "Installing leaf..."
fi

base_url="https://github.com/$REPO/releases/download/$tag_name"
tmp_file="$(mktemp)"
tmp_checksums="$(mktemp)"
rm -f "$tmp_file" "$tmp_checksums"
trap 'rm -f "$tmp_file" "$tmp_checksums"' EXIT

ensure_directory "$DEST_DIR"
download_file "$base_url/$asset_name" "$tmp_file"
download_file "$base_url/checksums.txt" "$tmp_checksums"

expected="$(grep "[[:space:]]${asset_name}$" "$tmp_checksums" | awk '{print $1}')"
if [[ -z "$expected" ]]; then
    log_error "Asset $asset_name not found in checksums.txt"
    exit 1
fi
if command_exists sha256sum; then
    actual="$(sha256sum "$tmp_file" | awk '{print $1}')"
else
    actual="$(shasum -a 256 "$tmp_file" | awk '{print $1}')"
fi
if [[ "$actual" != "$expected" ]]; then
    log_error "Checksum mismatch for $asset_name"
    exit 1
fi

cp "$tmp_file" "$DEST_BIN"
chmod 755 "$DEST_BIN"

if [[ -n "$current_version" ]]; then
    log_info "leaf updated from $current_version to ${tag_name#v}"
else
    log_info "leaf ${tag_name#v} installed"
fi
if [[ ":$PATH:" != *":$DEST_DIR:"* ]]; then
    log_warn "Add $DEST_DIR to PATH if needed."
fi
