#!/usr/bin/env bash

source "$(dirname -- "${BASH_SOURCE[0]}")/utils.sh"

install_packages ffmpeg cmus ani-cli
install_packages imagemagick qrencode lsix

for tool in piper-tts  \
            obs-cli; do
    uv tool install --upgrade $tool
done

ensure_directory "$HOME/.local/bin"

YT_DLP_VERSION="2026.03.17"
YT_DLP_PATH="$HOME/.local/bin/yt-dlp"
YT_DLP_URL="https://github.com/yt-dlp/yt-dlp/releases/download/${YT_DLP_VERSION}/yt-dlp_linux"
if [[ -x "$YT_DLP_PATH" ]] && [[ "$("$YT_DLP_PATH" --version 2>/dev/null)" == "$YT_DLP_VERSION" ]]; then
    log_info "yt-dlp version $YT_DLP_VERSION already installed; skipping download"
else
    trash_path "$YT_DLP_PATH"
    download_file "$YT_DLP_URL" "$YT_DLP_PATH" && chmod +x "$YT_DLP_PATH"
fi
