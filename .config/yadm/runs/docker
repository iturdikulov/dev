#!/usr/bin/env bash

source "$(dirname -- "${BASH_SOURCE[0]}")/utils.sh"

## Apt
## https://docs.docker.com/engine/install/debian/

docker_keyring="/etc/apt/keyrings/docker.asc"
docker_source="/etc/apt/sources.list.d/docker.list"
docker_repo="deb [arch=$(dpkg --print-architecture) signed-by=${docker_keyring}] https://download.docker.com/linux/debian $(. /etc/os-release && echo "$VERSION_CODENAME") stable"
docker_repo_added=0

install_packages ca-certificates curl

if [ ! -f "$docker_keyring" ]; then
  log_info "Adding Docker APT key..."
  sudo install -m 0755 -d /etc/apt/keyrings
  sudo curl -fsSL https://download.docker.com/linux/debian/gpg -o "$docker_keyring"
  sudo chmod a+r "$docker_keyring"
  docker_repo_added=1
else
  log_info "Docker APT key is already installed"
fi

if [ ! -f "$docker_source" ] || ! grep -Fxq "$docker_repo" "$docker_source"; then
  log_info "Adding Docker APT repository..."
  echo "$docker_repo" | sudo tee "$docker_source" > /dev/null
  docker_repo_added=1
else
  log_info "Docker APT repository is already configured"
fi

if [ "$docker_repo_added" -eq 1 ]; then
  sudo apt-get update
fi

# NVIDIA Container Toolkit
install_packages ca-certificates curl gnupg2

curl -fsSL https://nvidia.github.io/libnvidia-container/gpgkey | sudo gpg --dearmor -o /usr/share/keyrings/nvidia-container-toolkit-keyring.gpg \
  && curl -s -L https://nvidia.github.io/libnvidia-container/stable/deb/nvidia-container-toolkit.list | \
    sed 's#deb https://#deb [signed-by=/usr/share/keyrings/nvidia-container-toolkit-keyring.gpg] https://#g' | \
    sudo tee /etc/apt/sources.list.d/nvidia-container-toolkit.list

sudo apt-get update

export NVIDIA_CONTAINER_TOOLKIT_VERSION=1.19.0-1
  sudo apt-get install -y \
      nvidia-container-toolkit=${NVIDIA_CONTAINER_TOOLKIT_VERSION} \
      nvidia-container-toolkit-base=${NVIDIA_CONTAINER_TOOLKIT_VERSION} \
      libnvidia-container-tools=${NVIDIA_CONTAINER_TOOLKIT_VERSION} \
      libnvidia-container1=${NVIDIA_CONTAINER_TOOLKIT_VERSION}

# Install
install_packages docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin

# Post install
sudo usermod -aG docker "$USER"

# Lazydocker
go install github.com/jesseduffield/lazydocker@latest

# Devcontainers
npm install -g @devcontainers/cli
