#!/usr/bin/env bash

source "$(dirname -- "${BASH_SOURCE[0]}")/utils.sh"

DESKFLOW_VERSION="1.26.0"
PKGURL="https://github.com/deskflow/deskflow/releases/download/v${DESKFLOW_VERSION}/deskflow-${DESKFLOW_VERSION}-debian-trixie-x86_64.deb"
TMP_DEB="/tmp/deskflow-${DESKFLOW_VERSION}.deb"

if command_exists deskflow && deskflow --version 2>/dev/null | grep -Fq "Deskflow: ${DESKFLOW_VERSION}"; then
    log_info "Deskflow ${DESKFLOW_VERSION} is already installed; skipping download"
else
    download_file "$PKGURL" "$TMP_DEB"
    sudo apt install -f "$TMP_DEB"
    rm -f "$TMP_DEB"
fi

sudo ufw allow 24800/tcp
