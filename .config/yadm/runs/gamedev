#!/usr/bin/env bash

source "$(dirname -- "${BASH_SOURCE[0]}")/utils.sh"

install_packages libsdl2-dev

# Raylib
# TODO: Switch to `install_packages libraylib-dev` when raylib can be pulled from apt without adding extra sources (direct .deb install is only for avoiding sources changes).
install_packages libglfw3-dev

RAYLIB_POOL_BASE="https://deb.debian.org/debian/pool/main/r/raylib"
RAYLIB_DEB_VERSION="${RAYLIB_DEB_VERSION:-5.5+ds-1}"
ARCH="$(dpkg --print-architecture)"

raylib_debs_uptodate() {
    package_installed libraylib-dev &&
        package_installed libraylib550 &&
        [[ "$(dpkg-query -W -f='${Version}' libraylib-dev 2>/dev/null || true)" == "$RAYLIB_DEB_VERSION" ]] &&
        [[ "$(dpkg-query -W -f='${Version}' libraylib550 2>/dev/null || true)" == "$RAYLIB_DEB_VERSION" ]]
}

if raylib_debs_uptodate; then
    log_info "raylib Debian packages at $RAYLIB_DEB_VERSION ($ARCH) already installed"
else
    RAYLIB_TMP=$(mktemp -d) || exit 1
    RUN_DEB="$RAYLIB_TMP/libraylib550_${RAYLIB_DEB_VERSION}_${ARCH}.deb"
    DEV_DEB="$RAYLIB_TMP/libraylib-dev_${RAYLIB_DEB_VERSION}_${ARCH}.deb"
    download_file "${RAYLIB_POOL_BASE}/libraylib550_${RAYLIB_DEB_VERSION}_${ARCH}.deb" "$RUN_DEB" || exit 1
    download_file "${RAYLIB_POOL_BASE}/libraylib-dev_${RAYLIB_DEB_VERSION}_${ARCH}.deb" "$DEV_DEB" || exit 1
    # mktemp -d is 0700; apt's pkgAcquire runs as _apt and must read local .deb paths.
    chmod a+rx -- "$RAYLIB_TMP"
    chmod a+r -- "$RUN_DEB" "$DEV_DEB"
    apt_update_if_needed
    sudo apt install -y "$RUN_DEB" "$DEV_DEB" || exit 1
    rm -rf "$RAYLIB_TMP"
fi
