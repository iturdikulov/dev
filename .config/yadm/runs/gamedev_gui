#!/usr/bin/env bash

source "$(dirname -- "${BASH_SOURCE[0]}")/utils.sh"

# TODO: parametrize!

mkdir -p ~/.local/bin
cd ~/.local/bin || exit 1

VERSION=4.7-beta1
APP="Godot_v${VERSION}_mono_linux_x86_64"
GODOT_BIN="Godot_v${VERSION}_mono_linux.x86_64"
GODOT_EXTRACT_DIR="$HOME/.local/bin/$APP"
GODOT_VERSION_OUTPUT="${VERSION/-beta/.beta}"
URL="https://godot-releases.nbg1.your-objectstorage.com/${VERSION}/${APP}.zip"

if [ -x "$HOME/.local/bin/godot" ] &&
    "$HOME/.local/bin/godot" --version | grep -Eq "^${VERSION}|^${GODOT_VERSION_OUTPUT}" &&
    [ -d "$HOME/.local/bin/GodotSharp" ]; then
    log_info "Godot $VERSION is already installed"
else
    install_archive "godot" "$URL" "$VERSION" "$HOME/.local/bin" "zip" || exit 1
    if [ ! -d "$GODOT_EXTRACT_DIR" ]; then
        log_error "Godot archive did not extract to expected directory: $GODOT_EXTRACT_DIR"
        exit 1
    fi

    trash_path "$HOME/.local/bin/GodotSharp"
    trash_path "$HOME/.local/bin/godot"
    mv "$GODOT_EXTRACT_DIR"/* "$HOME/.local/bin"
    trash_path "$GODOT_EXTRACT_DIR"
    mv "$HOME/.local/bin/$GODOT_BIN" "$HOME/.local/bin/godot"
fi

# LAUNCHER
echo "[Desktop Entry]
Name=Godot Engine
GenericName=Libre game engine
Comment=Multi-platform 2D and 3D game engine with a feature-rich editor
Exec=$HOME/.local/bin/godot %f
Icon=$HOME/.local/bin/icons/godot.svg
Terminal=false
PrefersNonDefaultGPU=true
Type=Application
MimeType=application/x-godot-project;
Categories=Development;IDE;
StartupWMClass=Godot" > $HOME/.local/share/applications/godot.desktop
