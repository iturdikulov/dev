#!/usr/bin/env bash

source "$(dirname -- "${BASH_SOURCE[0]}")/utils.sh"

sudo dpkg --add-architecture i386

install_packages steam-installer icoutils
install_packages goverlay lutris antimicro dolphin-emu pcsx2

# rpcs3 — official latest Linux AppImage
RPCS3_URL="https://rpcs3.net/latest-linux-x64"
RPCS3_APPIMAGE="$HOME/.local/bin/rpcs3.AppImage"

ensure_directory "$HOME/.local/bin"
if [ -x "$RPCS3_APPIMAGE" ]; then
    log_info "RPCS3 AppImage already exists at $RPCS3_APPIMAGE; skipping latest re-download"
else
    download_file "$RPCS3_URL" "$RPCS3_APPIMAGE" || exit 1
    chmod +x "$RPCS3_APPIMAGE"
fi

RPCS3_DESKTOP_CONTENT="[Desktop Entry]
Name=RPCS3
Comment=PlayStation 3 emulator and debugger
GenericName=PlayStation 3 Emulator
Exec=$RPCS3_APPIMAGE
Icon=applications-games
Terminal=false
Type=Application
Categories=Game;Emulator;
StartupNotify=true"

create_desktop_entry "rpcs3" "$RPCS3_DESKTOP_CONTENT"

# protonup-qt (version pin, idempotent download, stable launcher symlink)
PROTONUP_QT_VERSION="2.12.0"
PROTONUP_QT_URL="https://github.com/DavidoTek/ProtonUp-Qt/releases/download/v${PROTONUP_QT_VERSION}/ProtonUp-Qt-${PROTONUP_QT_VERSION}-x86_64.AppImage"
PROTONUP_QT_APPIMAGE="$HOME/.local/bin/ProtonUp-Qt_${PROTONUP_QT_VERSION}.AppImage"
PROTONUP_QT_LAUNCHER="$HOME/.local/bin/ProtonUp-Qt.AppImage"

ensure_directory "$HOME/.local/bin"
if [ "$(readlink -- "$PROTONUP_QT_LAUNCHER" 2>/dev/null)" = "$PROTONUP_QT_APPIMAGE" ] && [ -x "$PROTONUP_QT_APPIMAGE" ]; then
    log_info "ProtonUp-Qt $PROTONUP_QT_VERSION is already installed"
else
    download_file "$PROTONUP_QT_URL" "$PROTONUP_QT_APPIMAGE" || exit 1
    chmod +x "$PROTONUP_QT_APPIMAGE"
    ln -sf "$PROTONUP_QT_APPIMAGE" "$PROTONUP_QT_LAUNCHER"
fi

PROTONUP_QT_DESKTOP_CONTENT="[Desktop Entry]
Version=$PROTONUP_QT_VERSION
Name=ProtonUp-Qt
Comment=Install and manage Proton-GE and Luxtorpeda for Steam and Wine-GE for Lutris
GenericName=ProtonUp-Qt
Exec=$PROTONUP_QT_LAUNCHER
Icon=games-config-options
Terminal=false
Type=Application
Categories=GTK;Game
StartupNotify=true"

create_desktop_entry "ProtonUp-Qt" "$PROTONUP_QT_DESKTOP_CONTENT"

# citron — nightly Linux AppImage from citron-neo/CI (pin SHA when upgrading)
CITRON_NIGHTLY_SHA="cf6129959"
CITRON_APPIMAGE_BASENAME="citron_nightly-${CITRON_NIGHTLY_SHA}-linux-x86_64.AppImage"
CITRON_URL="https://github.com/citron-neo/CI/releases/download/nightly-linux/${CITRON_APPIMAGE_BASENAME}"
CITRON_APPIMAGE="$HOME/.local/bin/$CITRON_APPIMAGE_BASENAME"
CITRON_LAUNCHER="$HOME/.local/bin/citron.AppImage"

ensure_directory "$HOME/.local/bin"
if [ "$(readlink -- "$CITRON_LAUNCHER" 2>/dev/null)" = "$CITRON_APPIMAGE" ] && [ -x "$CITRON_APPIMAGE" ]; then
    log_info "Citron nightly ($CITRON_NIGHTLY_SHA) is already installed"
else
    download_file "$CITRON_URL" "$CITRON_APPIMAGE" || exit 1
    chmod +x "$CITRON_APPIMAGE"
    ln -sf "$CITRON_APPIMAGE" "$CITRON_LAUNCHER"
fi

CITRON_DESKTOP_CONTENT="[Desktop Entry]
Version=nightly-$CITRON_NIGHTLY_SHA
Name=Citron
Comment=Nintendo Switch Emulator (nightly CI build)
GenericName=Citron Emulator
Exec=$CITRON_LAUNCHER
Icon=applications-games
Terminal=false
Type=Application
Categories=Game;Emulator;
StartupNotify=true"

create_desktop_entry "citron" "$CITRON_DESKTOP_CONTENT"

CITRON_KEYS_DIR="$HOME/.local/share/citron/keys"
CITRON_FIRMWARE_DIR="$HOME/.local/share/citron/nand/system/Contents/registered"

ensure_directory "$CITRON_KEYS_DIR"
ensure_directory "$CITRON_FIRMWARE_DIR"

cd_or_exit /tmp

if [[ -n "$(find "$CITRON_KEYS_DIR" -type f -name '*.keys' -print -quit 2>/dev/null)" ]]; then
    log_info "Citron prod keys already present; skipping ProdKeys download"
else
    rm -rf ProdKeys ProdKeys.zip
    wget --progress=bar --output-document ProdKeys.zip https://files.prodkeys.net/ProdKeys.NET-v20.4.0.zip
    unzip ProdKeys.zip -d ProdKeys && rm ProdKeys.zip
    cp -r ProdKeys/*/*.keys "$CITRON_KEYS_DIR"
    rm -rf ProdKeys
fi

if [[ -n "$(find "$CITRON_FIRMWARE_DIR" -mindepth 1 -print -quit 2>/dev/null)" ]]; then
    log_info "Citron firmware already present; skipping firmware download"
else
    rm -rf Firmware Firmware.zip
    wget --progress=bar --output-document Firmware.zip https://github.com/THZoria/NX_Firmware/releases/download/20.4.0/Firmware.20.4.0.zip
    unzip Firmware.zip -d Firmware && rm Firmware.zip
    cp -r Firmware/* "$CITRON_FIRMWARE_DIR"
    rm -rf Firmware
fi

install_packages flatpak
flatpak remote-add --user --if-not-exists flathub https://flathub.org
flatpak install --user -y flathub org.libretro.RetroArch
flatpak override --user --filesystem="$HOME/Media/games/RetroArch/" org.libretro.RetroArch
