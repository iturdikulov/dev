#!/usr/bin/env bash

source "$(dirname -- "${BASH_SOURCE[0]}")/utils.sh"

DOTNET_SDK_PACKAGE="dotnet-sdk-10.0"
MICROSOFT_REPO_PACKAGE="packages-microsoft-prod"
MICROSOFT_REPO_DEB="/tmp/$MICROSOFT_REPO_PACKAGE.deb"

if [ ! -f /etc/os-release ]; then
    log_error "Cannot detect OS release"
    exit 1
fi

# shellcheck disable=SC1091
source /etc/os-release

if [ "$ID" != "debian" ]; then
    log_error "Microsoft .NET APT repository setup is only configured for Debian"
    exit 1
fi

if ! package_installed "$MICROSOFT_REPO_PACKAGE"; then
    MICROSOFT_REPO_URL="https://packages.microsoft.com/config/debian/${VERSION_ID}/${MICROSOFT_REPO_PACKAGE}.deb"

    log_info "Installing Microsoft package repository for Debian $VERSION_ID..."
    download_file "$MICROSOFT_REPO_URL" "$MICROSOFT_REPO_DEB" || exit 1
    sudo dpkg -i "$MICROSOFT_REPO_DEB"
    rm -f "$MICROSOFT_REPO_DEB"
    sudo apt-get update
else
    log_info "Microsoft package repository is already installed"
fi

install_packages "$DOTNET_SDK_PACKAGE"
