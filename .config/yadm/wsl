#!/usr/bin/env bash

set -euo pipefail

# Increase wsl size
sudo mount -o remount,size=6G /tmp

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
cd "$script_dir"
# shellcheck source=runs/utils.sh
source "$script_dir/runs/utils.sh"

"$script_dir/run_runner.sh" --no-gui --no-ufw --blacklist "01_debian _hardware nvidia xone games gamedev _media _virt borg nginx resilio-sync singbox ttyd.sh whisper ollama_v2025"

SYNC_DIRS_WSL=(
    Desktop/atd
    Desktop/web
    Desktop/programming
    Templates
    Wiki
    Library/dictionary
)

read -rp "Source base path for sync, e.g. user@host:/home/user (empty to skip): " BASE_PATH

if [[ -n "$BASE_PATH" ]]; then
    OUTPUT_DIR="${SYNC_DEST:-$HOME}"

    read -rp "Sync .ssh plus WSL dirs (${SYNC_DIRS_WSL[*]}) into '$OUTPUT_DIR'? (y/n) "
    if [[ "$REPLY" =~ ^[Yy]$ ]]; then
        rcp --exclude .ssh/known_hosts "$BASE_PATH/.ssh" "$OUTPUT_DIR"
        for dir in "${SYNC_DIRS_WSL[@]}"; do
            rcp --relative "$BASE_PATH/$dir" "$OUTPUT_DIR"
        done
    fi
fi
