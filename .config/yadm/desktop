#!/usr/bin/env bash

set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
cd "$script_dir"
# shellcheck source=runs/utils.sh
source "$script_dir/runs/utils.sh"

sudo apt install -y firmware-amd-graphics i2c-tools libgl1-mesa-dri libglx-mesa0 mesa-vulkan-drivers power-profiles-daemon hipcc
sudo usermod -a -G render,video "$LOGNAME" # Add the current user to the render, video and printer groups

# Add nct6687d for MS-7C95-B550M-PRO-VDH
cd /tmp || exit 1
git clone https://github.com/Fred78290/nct6687d
cd nct6687d || exit 1
make deb
sudo dpkg -i ../nct6687d-dkms_*.deb

# Copy config if not exits
if ! [ -e /etc/sensors.d/MS-7C95-B550M-PRO-VDH.conf ]; then
    sudo ln "$script_dir/desktop_conf/etc/sensors.d/MS-7C95-B550M-PRO-VDH.conf" /etc/sensors.d/
    echo "Sensors config linked successfully."
fi

# Load i2c-dev at boot (/dev/i2c-*)
if ! [ -e /etc/modules-load.d/i2c-dev.conf ]; then
    sudo apt install -y i2c-tools
    sudo ln "$script_dir/desktop_conf/etc/modules-load.d/i2c-dev.conf" /etc/modules-load.d/
    sudo modprobe i2c-dev || true
    echo "modules-load.d i2c-dev linked successfully."
fi

"$script_dir/run_runner.sh"

SYNC_DIRS_DEFAULT=(
    Desktop/web
    Desktop/software
    Music
    Templates
    .password-store
    .config/microsoft-edge
)

read -rp "Source base path for sync, e.g. user@host:/home/user (empty to skip): " BASE_PATH

if [[ -n "$BASE_PATH" ]]; then
    OUTPUT_DIR="${SYNC_DEST:-$HOME}"

    read -rp "Sync .ssh plus desktop dirs (${SYNC_DIRS_DEFAULT[*]}) into '$OUTPUT_DIR'? (y/n) "
    if [[ "$REPLY" =~ ^[Yy]$ ]]; then
        rcp --exclude .ssh/known_hosts "$BASE_PATH/.ssh" "$OUTPUT_DIR"
        for dir in "${SYNC_DIRS_DEFAULT[@]}"; do
            rcp --relative "$BASE_PATH/$dir" "$OUTPUT_DIR"
        done
    fi
fi
