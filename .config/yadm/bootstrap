#!/usr/bin/env bash

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"

sudo apt install -y wget2 curl

# Change shell && reopen script in zsh if not already
sudo chsh -s $(which zsh)
sudo chsh -s $(which zsh) $(whoami)

if [[ "$SHELL" != *zsh ]]; then
    # Re-exec with zsh
    exec zsh "$0" "$@"
fi

# Source common utilities
source "$script_dir/runs/utils.sh"

# Because Git submodule commands cannot operate without a work tree, they must
# be run from within $HOME (assuming this is the root of your dotfiles)
cd "$HOME" || exit 1

git config --global user.email "i@inomoz.ru"
git config --global user.name "Inom T."

echo
PS3="Runner #: "
select opt in desktop laptop wsl skip; do
    case $opt in
        desktop | laptop | wsl)
            log_info "Starting $opt bootstrap..."
            bash "$script_dir/$opt"
            exit $?
            ;;
        skip)
            log_info "Skipped. Run ~/.config/yadm/desktop, laptop, or wsl when ready."
            exit 0
            ;;
        *)
            echo "Invalid choice."
            ;;
    esac
done

# Sync submodules
yadm submodule update --recursive --init

