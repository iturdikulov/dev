# Run `ghostty +show-config --default --docs` to view a list of
# all available config options and their default values.
#
# Additionally, each config option is also explained in detail
# on Ghostty's website, at https://ghostty.org/docs/config.
font-family = IosevkaTerm Nerd Font
font-size = 18
window-padding-y = 0
cursor-style = block
cursor-style-blink = false
shell-integration-features = no-cursor
command = zsh -c 'tmux attach || tmux new'
theme = kanso-zen
gtk-custom-css = tab-style.css

# --- Layout-agnostic Ctrl+letter ---
# Without this, switching to a non-Latin layout (e.g. RU) breaks ctrl+c, ctrl+r,
# etc. — Ghostty matches the translated character, so ctrl+с (Cyrillic) doesn't
# match ctrl+c (Latin) and emits raw `82;5u`-style sequences instead of ^C.
# `physical:` matches the physical key position regardless of layout.
# Skipping i/j/m to avoid colliding with Tab/LF/Enter.
# Refs:
#   https://github.com/ghostty-org/ghostty/issues/7309
#   https://github.com/ghostty-org/ghostty/discussions/3584
#   https://github.com/ghostty-org/ghostty/issues/3513
keybind = ctrl+physical:a=text:\x01
keybind = ctrl+physical:b=text:\x02
keybind = ctrl+physical:c=text:\x03
keybind = ctrl+physical:d=text:\x04
keybind = ctrl+physical:e=text:\x05
keybind = ctrl+physical:f=text:\x06
keybind = ctrl+physical:g=text:\x07
keybind = ctrl+physical:h=text:\x08
keybind = ctrl+physical:k=text:\x0b
keybind = ctrl+physical:l=text:\x0c
keybind = ctrl+physical:n=text:\x0e
keybind = ctrl+physical:o=text:\x0f
keybind = ctrl+physical:p=text:\x10
keybind = ctrl+physical:q=text:\x11
keybind = ctrl+physical:r=text:\x12
keybind = ctrl+physical:s=text:\x13
keybind = ctrl+physical:t=text:\x14
keybind = ctrl+physical:u=text:\x15
keybind = ctrl+physical:v=text:\x16
keybind = ctrl+physical:w=text:\x17
keybind = ctrl+physical:x=text:\x18
keybind = ctrl+physical:y=text:\x19
keybind = ctrl+physical:z=text:\x1a
