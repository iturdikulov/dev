!! X11 defaults
*.foreground: #CECECE
*.background: #0E1415
*.cursorColor: #BF68D9

!! Default font for classic X applications
*.font: xft:IosevkaTerm Nerd Font Mono:pixelsize=16:antialias=true:autohint=true

!! xterm
XTerm*foreground: #CECECE
XTerm*background: #0E1415
XTerm*faceName: IosevkaTerm Nerd Font Mono
XTerm*faceSize: 16
XTerm*termName: xterm-256color
XTerm*internalBorder: 0
XTerm*clientDecoration: none
XTerm*scrollBar: false
XTerm*saveLines: 10000
XTerm*cursorColor: #BF68D9
XTerm*decTerminalID: 340
XTerm*numColorRegisters: 256
XTerm.vt100.metaSendsEscape: true
XTerm.vt100.backarrowKey: false
XTerm.ttyModes: erase ^?
XTerm.vt100.translations: #override \n\
    Ctrl Shift <Key>C: copy-selection(CLIPBOARD) \n\
    Ctrl Shift <Key>V: insert-selection(CLIPBOARD)

!! uxterm
UXTerm*foreground: #CECECE
UXTerm*background: #0E1415
UXTerm*faceName: IosevkaTerm Nerd Font Mono
UXTerm*faceSize: 16
UXTerm*termName: xterm-256color
UXTerm*internalBorder: 0
UXTerm*clientDecoration: none
UXTerm*scrollBar: false
UXTerm*saveLines: 10000
UXTerm*cursorColor: #BF68D9
UXTerm*decTerminalID: 340
UXTerm*numColorRegisters: 256
UXTerm.vt100.metaSendsEscape: true
UXTerm.vt100.backarrowKey: false
UXTerm.ttyModes: erase ^?
UXTerm.vt100.translations: #override \n\
    Ctrl Shift <Key>C: copy-selection(CLIPBOARD) \n\
    Ctrl Shift <Key>V: insert-selection(CLIPBOARD)

!! DPI scaling for Xft-aware apps
Xft.dpi: 144
